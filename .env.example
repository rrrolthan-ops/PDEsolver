# Copy this file to .env and fill in the values you need.

# --- LLM (used only as a SEMANTIC CLASSIFIER in Phase 3 / Vision Stage C) ---
# Never used to resolve PDEs. Resolution is 100% symbolic (SymPy).
ANTHROPIC_API_KEY=

# --- Math OCR (Phase 4, optional premium engine) ---
# Leave empty to use pix2tex / Nougat (open-source defaults).
MATHPIX_API_KEY=
MATHPIX_APP_ID=

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/pdesolver.db

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
